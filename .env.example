# AI Provider: 'ollama' or 'openai'
AI_PROVIDER=ollama

# Ollama settings (when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI settings (when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# MySQL Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=vulnaibank

# Flask
SECRET_KEY=super-secret-key-do-not-change
FLASK_DEBUG=1
FLASK_PORT=5000
